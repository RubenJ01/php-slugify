{
    "name": "rjds/php-slugify",
    "description": "A PHP library to convert a string into a clean URL-safe lowercase string.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Rjds\\PhpSlugify\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Rjds\\PhpSlugify\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Ruben Eekhof",
            "email": "rubeneekhof@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-intl": "*"
    },
    "require-dev": {
        "phpro/grumphp": "^1.13 || ^2.0",
        "phpunit/phpunit": "^10.5 || ^11.0 || ^12.0 || ^13.0",
        "squizlabs/php_codesniffer": "^3.10 || ^4.0",
        "phpstan/phpstan": "^1.12 || ^2.0",
        "infection/infection": "^0.27 || ^0.32"
    },
    "config": {
        "allow-plugins": {
            "phpro/grumphp": true,
            "infection/extension-installer": true
        }
    }
}
